# ── Database ─────────────────────────────────────────────
# 로컬 개발은 SQLite. 운영 시 PostgreSQL(예: Supabase)로 교체 권장.
DATABASE_URL="file:./dev.db"

# ── 지도 API 키 ───────────────────────────────────────────
# 네이버 지도 (https://www.ncloud.com -> AI·NAVER API -> Maps)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=""

# 구글 지도 (https://console.cloud.google.com -> Maps JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# 기본 지도 공급자: "naver" 또는 "google"
NEXT_PUBLIC_DEFAULT_MAP_PROVIDER="naver"
