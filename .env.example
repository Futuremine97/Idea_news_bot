# ── Database ─────────────────────────────────────────────
# 로컬 개발은 SQLite. 운영 시 PostgreSQL(예: Neon/Supabase)로 교체. (DEPLOY.md 참고)
DATABASE_URL="file:./dev.db"

# ── 사이트 주소 (sitemap/robots/OG 에 사용) ──────────────
NEXT_PUBLIC_SITE_URL="https://idea-news-bot.vercel.app"

# ── 지도 표시용 (브라우저 노출 OK) ────────────────────────
# 네이버 지도 Client ID (Web Dynamic Map)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=""
# 구글 지도 (Maps JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# 기본 지도 공급자: "naver" 또는 "google"
NEXT_PUBLIC_DEFAULT_MAP_PROVIDER="naver"

# 카카오톡 공유용 JavaScript 키 (https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키)
# 없으면 카카오톡 버튼은 '링크 복사'로 폴백
NEXT_PUBLIC_KAKAO_JS_KEY=""

# ── 지오코딩(주소→좌표)용 서버 전용 키 (절대 NEXT_PUBLIC 아님!) ──
# 없으면 등록 폼에서 좌표 직접 입력 (지오코딩 버튼만 비활성)
NAVER_MAP_CLIENT_ID=""
NAVER_MAP_CLIENT_SECRET=""

# ── 관리자 검수 (/admin) 토큰 (서버 전용) ─────────────────
# 설정하면: 신규 등록이 'pending'(검수 대기)로 들어가고 /admin 에서 승인해야 노출.
# 미설정하면: 등록 즉시 노출(approved), /admin 비활성. 길고 무작위한 값 권장.
ADMIN_TOKEN=""

# ── Threads 자동 수집 봇 (공식 API) ───────────────────────
# https://developers.facebook.com 에서 앱 생성 → Threads API → 액세스 토큰 발급.
# threads_keyword_search 권한 승인 시 전체 공개 검색, 미승인 시 본인 게시물만.
THREADS_ACCESS_TOKEN=""
THREADS_KEYWORDS="AI agent,MCP server,ChatGPT GPT,Claude plugin,AI 서비스,AI 에이전트"
THREADS_SEARCH_TYPE="TOP"
