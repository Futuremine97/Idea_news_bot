generator client {
  provider = "prisma-client-js"
}

datasource db {
  // 운영: PostgreSQL (Neon). 로컬에서 SQLite로 되돌리려면 "sqlite" 로 변경.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 등록된 AI 서비스 / 에이전트 / 봇
model Service {
  id          String   @id @default(cuid())
  // 이름 (한/영)
  nameKo      String
  nameEn      String
  // 한 줄 소개 (한/영)
  taglineKo   String
  taglineEn   String
  // 상세 설명 (한/영)
  descKo      String
  descEn      String

  category    String   // 카테고리 (예: chatbot, marketing, dev-tool, vertical-agent ...)
  stage       String   @default("mvp")   // idea | pre-mvp | mvp | growth
  region      String   @default("global") // kr | us | global

  // 종류: service(일반 AI 서비스) | extension(플러그인/스킬/MCP 등)
  kind        String   @default("service")
  // extension 일 때 플랫폼: claude-plugin | claude-skill | chatgpt-gpt | chatgpt-skill | mcp | other
  platform    String?
  repoUrl     String?  // GitHub 등 소스/설치 저장소

  websiteUrl  String?
  instagramUrl String?
  logoUrl     String?
  pricing     String?  // free | freemium | paid | contact

  // 자영업자/오프라인 업체용 위치 정보 (선택)
  isLocalBiz  Boolean  @default(false)
  address     String?
  lat         Float?
  lng         Float?
  mapProvider String?  // naver | google

  // 등록자 정보
  submitterName  String?
  submitterEmail String?

  // 소유자 관리 토큰 (등록 시 발급, 비공개). 수정/삭제 시 검증용.
  ownerToken     String?

  // 출처: manual(직접등록) | collected(자동수집)
  source      String   @default("manual")
  sourceUrl   String?

  status      String   @default("approved") // pending | approved | rejected
  featured    Boolean  @default(false)
  views       Int      @default(0)
  upvotes     Int      @default(0)

  // 별점 집계 (평균 = ratingSum / ratingCount)
  ratingSum   Int      @default(0)
  ratingCount Int      @default(0)
  reviews     Review[]
  checkins    Checkin[]

  tags        String   @default("") // 쉼표 구분 태그

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([region])
  @@index([stage])
  @@index([status])
  @@index([kind])
  @@index([platform])
}

// 사용자 리뷰 / 별점
model Review {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  author    String   @default("익명")
  rating    Int      // 1~5
  body      String
  createdAt DateTime @default(now())

  @@index([serviceId])
}

// 사용자 체크인: 가볼 곳(going) / 저장(saved) / 가봤음(went)
// 로그인 없이 브라우저 visitorId 로 식별 (가벼운 신원). 사용자끼리 공개로 표시.
model Checkin {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  visitorId String   // 브라우저 localStorage UUID
  nickname  String   @default("게스트")
  status    String   // going | saved | went
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, visitorId])
  @@index([serviceId])
  @@index([visitorId])
  @@index([status])
}
